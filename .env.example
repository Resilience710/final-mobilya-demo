SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: server-only, NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# iyzico — sandbox keys for dev, production keys for prod
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# If you do not collect customer identity numbers yet, configure a verified
# merchant-level fallback for production instead of hardcoding placeholders.
IYZICO_BUYER_IDENTITY_NUMBER=

# Public site URL — used as iyzico callbackUrl (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# PayTR iFrame API
# Callback / Bildirim URL must also be configured in the PayTR merchant panel as:
# https://your-domain.com/api/payment/paytr/callback
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=0
PAYTR_DEBUG_ON=0
PAYTR_IFRAME_V2_DARK=0

# Manual bank transfer / EFT
BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_ACCOUNT_HOLDER=
BANK_TRANSFER_IBAN=
BANK_TRANSFER_BRANCH=
BANK_TRANSFER_ACCOUNT_NUMBER=
BANK_TRANSFER_NOTE=

# tawk.to live support widget
# Dashboard > Administration > Overview / Chat Widget
NEXT_PUBLIC_TAWK_TO_PROPERTY_ID=
NEXT_PUBLIC_TAWK_TO_WIDGET_ID=
